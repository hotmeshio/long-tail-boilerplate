{
  "name": "my-longtail-app",
  "version": "0.1.0",
  "private": true,
  "description": "Durable workflows with IAM, MCP tools, and a built-in dashboard. Powered by PostgreSQL.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "seed": "ts-node scripts/seed.ts",
    "token": "ts-node scripts/token.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hotmeshio/hotmesh": "^0.14.3",
    "@hotmeshio/long-tail": "^0.1.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^2.4.3",
    "pg": "^8.13.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.3.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.4",
    "vitest": "^4.1.2"
  }
}
