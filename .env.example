# Database (required)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=myapp

# Server
PORT=3030
JWT_SECRET=change-me-in-production

# File storage — MinIO (S3-compatible, included in docker-compose)
LT_STORAGE_BACKEND=s3
LT_S3_BUCKET=long-tail-files
LT_S3_ENDPOINT=http://localhost:9002
LT_S3_REGION=us-east-1
LT_S3_ACCESS_KEY=minioadmin
LT_S3_SECRET_KEY=minioadmin
LT_S3_FORCE_PATH_STYLE=true

# LLM (optional — enables MCP tool orchestration)
# ANTHROPIC_API_KEY=sk-ant-...

# OAuth (optional — enables user credential management)
# OAUTH_ENCRYPTION_KEY=...
# OAUTH_GOOGLE_CLIENT_ID=...
# OAUTH_GOOGLE_CLIENT_SECRET=...
