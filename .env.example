# Database (required)
# Local docker postgres (default — use POSTGRES_HOST=postgres for in-container access)
POSTGRES_HOST=localhost
POSTGRES_PORT=5416
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=myapp

# External postgres (e.g. another project — use host.docker.internal for in-container access)
# POSTGRES_HOST=host.docker.internal
# POSTGRES_PORT=5433
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=acme_workflow

# Server
PORT=3030
JWT_SECRET=change-me-in-production

# File storage — MinIO (S3-compatible, included in docker-compose)
LT_STORAGE_BACKEND=s3
LT_S3_BUCKET=long-tail-files
LT_S3_ENDPOINT=http://localhost:9002
LT_S3_REGION=us-east-1
LT_S3_ACCESS_KEY=minioadmin
LT_S3_SECRET_KEY=minioadmin
LT_S3_FORCE_PATH_STYLE=true

# LLM (optional — enables MCP tool orchestration)
# ANTHROPIC_API_KEY=sk-ant-...

# Integration tests: skip the LLM-driven self-test (tests/integration/self-test.test.ts).
# When an LLM key is set locally, that suite runs a live, non-deterministic LLM build of
# the longtailapi tools which can emit broken YAML and fail on invoke. CI has no LLM key
# and skips the build anyway; set this to 1 locally to match CI.
# SKIP_LLM_SELF_TEST=1

# OAuth (optional — enables user credential management)
# OAUTH_ENCRYPTION_KEY=...
# OAUTH_GOOGLE_CLIENT_ID=...
# OAUTH_GOOGLE_CLIENT_SECRET=...
